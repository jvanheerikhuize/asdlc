{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jvanheerikhuize/asdlc/spec/manifest.schema.json",
  "title": "asdlc.yaml — the one framework file a consuming repository carries",
  "type": "object",
  "required": ["spec_version", "role_bindings"],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Pinned asdlc-spec version. Governance upgrades are explicit, reviewable diffs to this line."
    },
    "baseline": {
      "type": "object",
      "description": "Repo-level classification floor from P0 onboarding; per-change classifications may go higher, never lower.",
      "properties": {
        "risk": { "enum": ["low", "medium", "high"] },
        "data": { "enum": ["none", "internal", "personal", "sensitive"] },
        "ai_system_tier": { "enum": ["none", "minimal", "limited", "high-risk"] }
      },
      "additionalProperties": false
    },
    "role_bindings": {
      "type": "object",
      "description": "Authority-matrix role → platform identities allowed to exercise it. A solo maintainer binds every role to one identity; the verifier records the standing SoD exception rather than hiding it.",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z-]*$": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "description": "e.g. github:login or github:org/team" }
        }
      },
      "additionalProperties": false
    },
    "bindings": {
      "type": "object",
      "description": "How gates map onto platform primitives. Never decides pass/fail — that is spec policy evaluated by the verifier (portability rule, risks.md R5).",
      "properties": {
        "provider": { "type": "string", "examples": ["github"] },
        "gates": {
          "type": "object",
          "patternProperties": {
            "^G[0-6]$": {
              "type": "object",
              "properties": {
                "mechanism": { "type": "string", "examples": ["required-check", "environment-protection"] },
                "config": { "type": "object" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "retention": {
      "type": "object",
      "description": "Evidence export target (mandatory from slice 4; declared here from day one).",
      "properties": {
        "target": { "type": "string", "description": "URI of the append-only store." },
        "schedule": { "type": "string", "description": "cron expression" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
