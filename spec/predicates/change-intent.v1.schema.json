{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jvanheerikhuize/asdlc/spec/predicates/change-intent.v1.schema.json",
  "title": "change-intent/v1 — why this change exists and when it is done",
  "allOf": [{ "$ref": "statement.base.schema.json" }],
  "properties": {
    "predicateType": {
      "const": "https://github.com/jvanheerikhuize/asdlc/spec/predicates/change-intent/v1"
    },
    "predicate": {
      "type": "object",
      "required": ["change_id", "title", "problem", "acceptance_criteria", "produced_by", "produced_at"],
      "properties": {
        "change_id": { "$ref": "statement.base.schema.json#/$defs/changeId" },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "problem": {
          "type": "string",
          "minLength": 1,
          "description": "The problem or need, stated independently of any solution."
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "out_of_scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "produced_by": { "$ref": "statement.base.schema.json#/$defs/producedBy" },
        "produced_at": { "$ref": "statement.base.schema.json#/$defs/producedAt" },
        "refs": { "$ref": "statement.base.schema.json#/$defs/refs" }
      },
      "additionalProperties": false
    }
  }
}
